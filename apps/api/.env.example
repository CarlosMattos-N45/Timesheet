# Habilita documentacao OpenAPI (Swagger UI) em /docs
# TIMESHEET_DEV=false

# Porta do servidor local
# TIMESHEET_PORT=8765

# Host do servidor local
# TIMESHEET_HOST=127.0.0.1

# URL de conexao do banco de dominio (SQLAlchemy async + aiosqlite)
# Em producao: SQLite + SQLCipher; em dev: SQLite simples se TIMESHEET_KEK_PATH ausente.
# TIMESHEET_DB_URL=sqlite+aiosqlite:///./data/timesheet.sqlite

# Chave SQLCipher em hex (64 chars = 256 bits). Gerada via crypto.format_db_cipher_key(). Ausente = banco sem criptografia.
# TIMESHEET_DB_CIPHER_KEY=

# Caminho para o arquivo KEK (chave mestra de criptografia). Gerado automaticamente se ausente.
# TIMESHEET_KEK_PATH=./data/key.kek

# Apenas dev — permite KEK em claro sem DPAPI.
# TIMESHEET_ALLOW_PLAIN_KEK=1

# Segredo HS256 do JWT. Obrigatorio em producao. Minimo 32 chars.
# TIMESHEET_JWT_SECRET=

# Rate limits (slowapi: N/unidade)
# TIMESHEET_RATE_LIMIT_LOGIN=5/minute
# TIMESHEET_RATE_LIMIT_REFRESH=10/minute

# Diretorio para armazenar PDFs gerados
# TIMESHEET_PDF_DIR=./data/pdfs

# Habilita o scheduler APScheduler (gera e envia relatorio mensalmente)
# TIMESHEET_SCHEDULER_ENABLED=true

# Caminho do banco SQLite para jobs do APScheduler
# TIMESHEET_SCHEDULER_JOBSTORE=./data/scheduler.sqlite

# Timeout em segundos para conexoes SMTP
# TIMESHEET_SMTP_TIMEOUT=30
