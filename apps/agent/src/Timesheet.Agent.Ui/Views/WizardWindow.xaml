<Window x:Class="Timesheet.Agent.Ui.Views.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro Inicial — Timesheet Terceiros"
        Width="480" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" x:Name="TxtPassoTitulo"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- Passo 1 -->
        <StackPanel Grid.Row="1" x:Name="PnlPasso1">
            <TextBlock Text="Nome completo" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtNome" Margin="0,0,0,12"/>

            <TextBlock Text="Empresa" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtEmpresa" Margin="0,0,0,12"/>

            <TextBlock Text="CNPJ" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtCnpj" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtCnpjErro" Foreground="Red" FontSize="11" Visibility="Collapsed"
                       Text="CNPJ inválido"/>
        </StackPanel>

        <!-- Passo 2 -->
        <StackPanel Grid.Row="1" x:Name="PnlPasso2" Visibility="Collapsed">
            <TextBlock Text="Início da jornada (HH:MM)" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtInicio" Margin="0,0,0,12"/>

            <TextBlock Text="Saída para almoço (HH:MM)" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtSaidaAlmoco" Margin="0,0,0,12"/>

            <TextBlock Text="Retorno do almoço (HH:MM)" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtRetornoAlmoco" Margin="0,0,0,12"/>

            <TextBlock Text="Fim da jornada (HH:MM)" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtFim" Margin="0,0,0,12"/>

            <CheckBox x:Name="ChkFds" Content="Trabalha aos finais de semana" Margin="0,4,0,0"/>

            <TextBlock x:Name="TxtHorariosErro" Foreground="Red" FontSize="11" Visibility="Collapsed"
                       Text="Os horários devem estar em ordem cronológica" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Passo 3 -->
        <StackPanel Grid.Row="1" x:Name="PnlPasso3" Visibility="Collapsed">
            <TextBlock Text="E-mail" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtEmail" Margin="0,0,0,12"/>

            <TextBlock Text="Senha (mín. 8 caracteres)" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PbSenha" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtForcaSenha" FontSize="11" Margin="0,0,0,8"/>

            <TextBlock Text="Confirmar senha" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PbSenhaConfirmacao" Margin="0,0,0,12"/>

            <TextBlock Text="E-mail destinatário de relatórios (opcional)" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtEmailDestinatario" Margin="0,0,0,4"/>
        </StackPanel>

        <!-- Botões -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnVoltar" Content="Voltar" Width="80" Margin="0,0,8,0"
                    Click="BtnVoltar_Click" IsEnabled="False"/>
            <Button x:Name="BtnAvancar" Content="Avançar" Width="80"
                    Click="BtnAvancar_Click"/>
        </StackPanel>
    </Grid>
</Window>
