<Window x:Class="Timesheet.Agent.Ui.Views.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timesheet Terceiros"
        Width="420" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtMensagem"
                   TextWrapping="Wrap" FontSize="14" Margin="0,0,0,12"/>

        <!-- Textarea para atividade (PROMPT_FIM_JORNADA) -->
        <TextBox Grid.Row="1" x:Name="TxtAtividade"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,8"
                 Visibility="Collapsed"/>

        <!-- Progress bar de contagem regressiva -->
        <ProgressBar Grid.Row="2" x:Name="PbContagem"
                     Height="8" Margin="0,0,0,4"/>

        <TextBlock Grid.Row="3" x:Name="TxtSegundos"
                   HorizontalAlignment="Right" FontSize="11"
                   Foreground="Gray" Margin="0,0,0,12"/>

        <!-- Botões -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnNao" Content="Não" Width="80" Margin="0,0,8,0"
                    Click="BtnNao_Click"/>
            <Button x:Name="BtnSim" Content="Sim" Width="80"
                    Click="BtnSim_Click"/>
        </StackPanel>
    </Grid>
</Window>
